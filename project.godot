; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Such Moon Launch"
run/main_scene="res://game/gui/menu/Menu.tscn"
config/features=PackedStringArray("4.6")
boot_splash/bg_color=Color(0.05, 0.05, 0.1, 1)
boot_splash/stretch_mode=0
boot_splash/image="res://art/branding/circuit_dark_w_text.png"
config/icon="res://art/branding/icon.png"

[autoload]

globalvar="*res://globalvar.gd"
ScoreClient="*res://game/net/ScoreClient.gd"
CloudSave="*res://game/net/CloudSave.gd"
AdManager="*res://game/net/AdManager.gd"
GodotPlayGameServices="*uid://bjuenlsq84yr1"
PlayGamesManager="*res://game/net/PlayGamesManager.gd"
GameCenterManager="*res://game/net/GameCenterManager.gd"
ShareService="*res://game/net/ShareService.gd"
IAPManager="*res://game/net/IAPManager.gd"
Telemetry="*res://game/net/Telemetry.gd"
WarpTransition="*res://game/warp/WarpTransition.gd"

[display]

window/size/viewport_width=1024
window/size/viewport_height=600
window/size/mode=3
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

[dotnet]

project/assembly_name="Such Moon Launch"

[editor_plugins]

enabled=PackedStringArray("res://addons/admob/plugin.cfg", "res://addons/GodotPlayGameServices/plugin.cfg")

