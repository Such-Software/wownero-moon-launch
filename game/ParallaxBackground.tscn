[node name="Starfield" type="ColorRect" parent="." unique_id=13292578]
material = SubResource("1")
; Massively over-sized rect that covers any expanded viewport. With Godot's
; canvas_items stretch + expand aspect, FULL_RECT anchors only cover the
; 1024x600 design area — the extra screen space on phones falls outside.
; Explicit large offsets guarantee coverage on any aspect ratio. The
; starfield shader uses SCREEN_UV so its star density looks the same
; regardless of the underlying rect size.
offset_left = -3000.0
offset_top = -3000.0
offset_right = 3000.0
offset_bottom = 3000.0
