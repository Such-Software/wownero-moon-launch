# Godot 4 - generated files
.godot/
.import/

# Godot uid files (auto-generated)
*.uid

# Mono/C#
.mono/
data_*/
mono_crash.*.json

# Export builds
builds/
*.aab
*.apk
*.apk.idsig
*.ipa
*.dmg
*.exe
*.x86_64
*.pck

# Android build artifacts
android/build/
android/.build_version

# OS/editor junk
**/.DS_Store
**/Thumbs.db
*.swp
*~
.vscode/

# Screenshots (optional - remove this line if you want them tracked)
# screenshots/
*.tmp
.syncthing*

# GdUnit4 test reports
reports/

# Ad setup guide (untracked, contains placeholder instructions)
ADS.md

# Deploy guide (untracked, contains signing/release instructions)
DEPLOY.md

# Capture sheet (untracked, contains production IDs / OAuth client IDs)
CAPTURE.md

# Signing material copied locally for headless builds (sandbox workaround)
.signing/

# AdMob downloaded native libraries (large binaries, per-machine)
addons/admob/downloads/
addons/admob/android/bin/
# AdMob iOS plugin (downloaded via the AdMob editor menu — per-machine).
# We ignore everything under ios/plugins/ EXCEPT the godot-storekit2 plugin
# we ship as a versioned release artifact (~2 MB).
ios/plugins/*
!ios/plugins/godot-storekit2.gdip
!ios/plugins/godot-storekit2.debug.xcframework
!ios/plugins/godot-storekit2.release.xcframework
